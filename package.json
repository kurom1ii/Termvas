{
  "name": "termvas",
  "displayName": "Termvas",
  "description": "Infinite canvas with terminal tiles for VSCode",
  "version": "0.1.0",
  "publisher": "kuromi",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:termvas.open",
    "onCommand:termvas.restart"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "termvas.open",
        "title": "Open Canvas",
        "category": "Termvas",
        "icon": "$(terminal)"
      },
      {
        "command": "termvas.restart",
        "title": "Restart Extension",
        "category": "Termvas"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "termvas.open",
          "group": "navigation@32",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/title": [
        {
          "command": "termvas.open",
          "group": "navigation@0",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "install-ext": "ln -sfn \"$(pwd)\" \"$HOME/.vscode-insiders/extensions/termvas\" && echo 'Installed! Reload VSCode (Ctrl+Shift+P → Reload Window).'",
    "uninstall-ext": "rm -f \"$HOME/.vscode-insiders/extensions/termvas\" && echo 'Removed.'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/addon-unicode11": "^0.8.0"
  }
}
